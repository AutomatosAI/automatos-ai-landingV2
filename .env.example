# Automatos v2 landing — env example.
# Set these on Railway. server.js hydrates _config.js from these at container start.

# ── Widget SDK auth (chat + blog) ─────────────────────────────────────
# ak_pub_* key. Allow-listed by origin server-side. Mint via:
#   POST /api/api-keys with { key_type: "public",
#     permissions: ["chat","blog"],
#     allowed_domains: ["automatos.app","www.automatos.app","localhost:8765"] }
VITE_AUTOMATOS_PUBLIC_KEY=ak_pub_your_key_here

# Workspace ID — used by the field-notes direct-fetch blog path
VITE_AUTOMATOS_WORKSPACE_ID=your_workspace_id_here

# Public-facing chat agent UUID (CONCIERGE or similar). Optional —
# falls back to workspace default if empty.
VITE_AUTOMATOS_CHAT_AGENT_ID=

# ── Contact form SMTP (Namecheap Private Email) ───────────────────────
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=Gerard@automatos.app
SMTP_PASS=your_email_password_here
CONTACT_EMAIL=Gerard@automatos.app

# ── Runtime ──────────────────────────────────────────────────────────
# Railway sets this automatically; uncomment for local dev.
# PORT=8080
